{
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-auxdir=.aux-files",
        "-outdir=pdf",
        "%DOC%"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": ["latexmk"]
    }
  ],
  "latex-workshop.latex.outDir": "%DIR%/pdf",
  "latex-workshop.latex.auxDir": "%DIR%/.aux-files",  
  "latex-workshop.message.latexlog.exclude": [
    "Please \\(re\\)run Biber",
    "Please rerun LaTeX",
    "There were undefined references",
    "Empty bibliography"
  ]
}
